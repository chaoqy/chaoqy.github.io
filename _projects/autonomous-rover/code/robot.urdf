<?xml version="1.0"?>
<robot name="1">


  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>


  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.25 0.2 0.06"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>


  <link name="laser">
    <visual>
      <geometry>
       <cylinder length="0.08" radius="0.035"/>
      </geometry>
      <origin rpy="0 0 0" xyz="-0.06 -0.045 0"/>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="0 0 0.06"/>
  </joint>


  <link name="front_left">
    <visual>
      <geometry>
        <cylinder length="0.055" radius="0.06"/>
      </geometry>
      <origin rpy="1.57075 0 0" xyz="0.095 0 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_front_left" type="continuous">
    <parent link="base_link"/>
    <child link="front_left"/>
    <origin xyz="0 0.1275 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <link name="front_right">
    <visual>
      <geometry>
        <cylinder length="0.055" radius="0.06"/>
      </geometry>
      <origin rpy="1.57075 0 0" xyz="0.095 0 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_front_right" type="continuous">
    <parent link="base_link"/>
    <child link="front_right"/>
    <origin xyz="0 -0.1275 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <link name="back_left">
    <visual>
      <geometry>
        <cylinder length="0.055" radius="0.06"/>
      </geometry>
      <origin rpy="1.57075 0 0" xyz="-0.095 0 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_back_left" type="continuous">
    <parent link="base_link"/>
    <child link="back_left"/>
    <origin xyz="0 0.1275 0"/>
    <axis xyz="0 1 0"/>
  </joint>


  <link name="back_right">
    <visual>
      <geometry>
        <cylinder length="0.055" radius="0.06"/>
      </geometry>
      <origin rpy="1.57075 0 0" xyz="-0.095 0 0"/>
      <material name="black"/>
    </visual>
  </link>

  <joint name="base_to_back_right" type="continuous">
    <parent link="base_link"/>
    <child link="back_right"/>
    <origin xyz="0 -0.1275 0"/>
    <axis xyz="0 1 0"/>
  </joint>


</robot>
